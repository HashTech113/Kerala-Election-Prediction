# Files that must NOT enter the Docker build context for the backend image.
# Keep this in sync with .railwayignore (Dockerfile is the source of truth on
# Railway; .railwayignore is a belt-and-suspenders against Nixpacks fallback).

# Frontend & node tooling — Railway must not see these
frontend/
node_modules/
package.json
package-lock.json

# Local dev / VCS / IDE
.git/
.github/
.vscode/
.idea/
*.log
.env
.env.*
.venv/
venv/

# Python build artefacts
**/__pycache__/
**/*.pyc
**/*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Trained model checkpoints — large, regenerated by train.py, not used by the API
backend/checkpoints/

# Platform metadata
.vercel/
.railway/

# Top-level scripts that aren't part of the runtime image
run.py

# Docs
README.md
docs/
.gitignore
.gitattributes

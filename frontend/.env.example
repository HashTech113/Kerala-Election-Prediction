# ============================================
# Frontend Environment Variables (Example Template)
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git!
# ============================================

# Backend API Base URL
# For LOCAL development:
VITE_API_BASE_URL=http://127.0.0.1:8001

# For RAILWAY production (replace with your actual backend URL):
# Get the URL from Railway Dashboard → Backend Project → Deployments → Public URL
# VITE_API_BASE_URL=https://your-backend-app.up.railway.app

# Alternative: You can also use VITE_API_URL (alias supported by api.ts)
# VITE_API_URL=http://127.0.0.1:8001

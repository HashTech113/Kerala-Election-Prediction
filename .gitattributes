# Normalize all text files to LF in the repository and working tree.
* text=auto eol=lf

# Keep Windows-native script files as CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Treat common binary assets as binary to avoid line-ending transforms.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.woff binary
*.woff2 binary
